{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dream-work-reality.local/integration/protocol/response.schema.json",
  "title": "Native Host to Extension JSON-RPC Success Response",
  "type": "object",
  "additionalProperties": false,
  "required": ["jsonrpc", "id", "result"],
  "properties": {
    "jsonrpc": {
      "type": "string",
      "const": "2.0"
    },
    "id": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "null" }
      ]
    },
    "result": {
      "type": "object"
    }
  }
}
