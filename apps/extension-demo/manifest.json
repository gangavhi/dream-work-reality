{
  "manifest_version": 3,
  "name": "DreamWork Demo Autofill",
  "version": "0.1.0",
  "description": "Demo extension to autofill local form from core-api.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://127.0.0.1:18081/*", "http://localhost:18081/*"],
  "action": {
    "default_popup": "popup.html"
  }
}
